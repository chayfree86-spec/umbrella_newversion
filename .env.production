# Auto-loaded by `npm run build` (Vite production mode). Bakes the live
# backend URL into the compiled JS so the deployed frontend on
# new-admin.umbrellafinance.co calls the API directly (CORS is allowed).
# Dev (`npm run dev`) ignores this and uses the vite.config.js /api proxy.
VITE_API_URL=https://new-api.umbrellafinance.co
