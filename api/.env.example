# Database Settings
DB_HOST=localhost
DB_NAME=ufin
DB_USER=root
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Authentication Settings
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY_HOURS=24

# CORS Settings (Comma-separated list of allowed origins)
# You can leave this blank to allow any subdomain of the same root domain
CORS_ALLOWED_ORIGINS=https://new-admin.umbrellafinance.co
